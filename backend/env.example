# ===========================================
# Backend Environment Variables
# ===========================================

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password123@postgres:5432/fastapi

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# TBO API Configuration
TBO_SHARED_BASE_URL=https://supply.travelboutiqueonline.com/Authentication/Authenticate
TBO_AIR_BASE_URL=https://supply.travelboutiqueonline.com/Air/Api
TBO_CLIENT_ID=your_tbo_client_id
TBO_USERNAME=your_tbo_username
TBO_PASSWORD=your_tbo_password
TBO_END_USER_IP=192.168.1.1

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Customer Support
SUPPORT_PHONE=+91-XXXXXXXXXX
SUPPORT_EMAIL=support@fareclubs.com

# SMTP Configuration (for staff alert emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@fareclubs.com
STAFF_ALERT_EMAILS=ops@fareclubs.com
