# ===========================================
# Backend Environment Variables
# ===========================================

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password123@postgres:5432/fastapi

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# TBO API Configuration
TBO_SHARED_BASE_URL=https://supply.travelboutiqueonline.com/Authentication/Authenticate
TBO_AIR_BASE_URL=https://supply.travelboutiqueonline.com/Air/Api
TBO_CLIENT_ID=your_tbo_client_id
TBO_USERNAME=your_tbo_username
TBO_PASSWORD=your_tbo_password
TBO_END_USER_IP=192.168.1.1

